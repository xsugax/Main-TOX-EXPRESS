# TOX Express - Environment Variables
# Copy this file to .env and fill in your values

# Gmail SMTP credentials
# For EMAIL_PASSWORD, use a Gmail App Password (NOT your regular password)
# To create one: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=thetoxexpressdeliveryservices@gmail.com
EMAIL_PASSWORD=your-gmail-app-password-here

# Admin panel password (used for SHA-256 authentication)
ADMIN_PASSWORD=ToxAdmin2026
