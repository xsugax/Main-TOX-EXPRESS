# TOX Express - Environment Variables
# Copy this file to .env and fill in your values

# === SMTP Email Config ===
# Option 1: Brevo (recommended - free, easy setup)
#   Sign up at brevo.com → Settings → SMTP & API → SMTP
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-login-email
EMAIL_PASSWORD=your-brevo-smtp-key

# Option 2: Gmail (requires App Password + 2FA)
#   Remove EMAIL_HOST and EMAIL_PORT lines
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASSWORD=your-app-password

# Option 3: Any SMTP provider
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-username
# EMAIL_PASSWORD=your-password

# Admin panel password (SHA-256 authentication)
ADMIN_PASSWORD=ToxAdmin2026
